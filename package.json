{
    "name": "supersplat",
    "version": "2.23.1",
    "author": "PlayCanvas<support@playcanvas.com>",
    "homepage": "https://playcanvas.com/supersplat/editor",
    "description": "3D Gaussian Splat Editor",
    "keywords": [
        "playcanvas",
        "ply",
        "gaussian",
        "splat",
        "editor"
    ],
    "license": "MIT",
    "main": "index.js",
    "scripts": {
        "db:init:opentour": "python ./scripts/init_opentour_db.py",
        "build": "rollup -c",
        "watch": "rollup -c -w",
        "build:opentour": "cross-env BUILD_TYPE=release rollup -c rollup.config.opentour.mjs",
        "watch:opentour": "cross-env BUILD_TYPE=debug rollup -c rollup.config.opentour.mjs -w",
        "build:openmesh": "cross-env BUILD_TYPE=release rollup -c rollup.config.openmesh.mjs",
        "build:glb-assets": "node scripts/openmesh-export/build-bronze-glb.mjs",
        "build:showcase2:scan": "node scripts/showcase2/scan-assets.mjs",
        "build:showcase2:resolve": "node scripts/showcase2/resolve-paths.mjs",
        "build:showcase2:classify": "node scripts/showcase2/classify-textures.mjs",
        "build:showcase2-assets": "node scripts/showcase2/build-showcase2-assets.mjs",
        "watch:openmesh": "cross-env BUILD_TYPE=debug rollup -c rollup.config.openmesh.mjs -w",
        "serve:openmesh": "node scripts/openmesh-server.mjs",
        "develop:openmesh": "concurrently --kill-others \"npm run watch:openmesh\" \"npm run serve:openmesh\"",
        "build:ot-model-loader": "cross-env BUILD_TYPE=release rollup -c rollup.config.ot-model-loader.mjs",
        "watch:ot-model-loader": "cross-env BUILD_TYPE=debug rollup -c rollup.config.ot-model-loader.mjs -w",
        "build:ot-tour-loader": "cross-env BUILD_TYPE=release rollup -c rollup.config.ot-tour-loader.mjs",
        "watch:ot-tour-loader": "cross-env BUILD_TYPE=debug rollup -c rollup.config.ot-tour-loader.mjs -w",
        "serve:ot-tour-loader": "node src/opentour/OT_TourLoader/backend/server.mjs",
        "develop:ot-tour-loader": "concurrently --kill-others \"npm run watch:ot-tour-loader\" \"npm run serve:ot-tour-loader\"",
        "build:ot-tour-player": "cross-env BUILD_TYPE=release rollup -c rollup.config.ot-tour-player.mjs",
        "watch:ot-tour-player": "cross-env BUILD_TYPE=debug rollup -c rollup.config.ot-tour-player.mjs -w",
        "serve:ot-tour-player": "node src/opentour/OT_TourPlayer/backend/server.mjs",
        "develop:ot-tour-player": "concurrently --kill-others \"npm run watch:ot-tour-player\" \"npm run serve:ot-tour-player\"",
        "build:ot-tour-download": "cross-env BUILD_TYPE=release rollup -c rollup.config.ot-tour-download.mjs",
        "watch:ot-tour-download": "cross-env BUILD_TYPE=debug rollup -c rollup.config.ot-tour-download.mjs -w",
        "serve:ot-tour-download": "node src/opentour/OT_TourDownload/backend/server.mjs",
        "develop:ot-tour-download": "concurrently --kill-others \"npm run watch:ot-tour-download\" \"npm run serve:ot-tour-download\"",
        "build:ot-tour-producer": "cross-env BUILD_TYPE=release rollup -c rollup.config.ot-tour-producer.mjs",
        "watch:ot-tour-producer": "cross-env BUILD_TYPE=debug rollup -c rollup.config.ot-tour-producer.mjs -w",
        "serve:ot-tour-producer": "node src/opentour/OT_TourProducer/backend/server.mjs",
        "develop:ot-tour-producer": "concurrently --kill-others \"npm run watch:ot-tour-producer\" \"npm run serve:ot-tour-producer\"",
        "build:ot-live-stream": "cross-env BUILD_TYPE=release rollup -c rollup.config.ot-live-stream.mjs",
        "watch:ot-live-stream": "cross-env BUILD_TYPE=debug rollup -c rollup.config.ot-live-stream.mjs -w",
        "serve:ot-live-stream": "node src/opentour/OT_LiveStream/backend/server.mjs",
        "develop:ot-live-stream": "concurrently --kill-others \"npm run watch:ot-live-stream\" \"npm run serve:ot-live-stream\"",
        "serve": "serve dist -C",
        "serve:opentour": "node scripts/opentour-server.mjs",
        "develop:opentour": "concurrently --kill-others \"npm run watch:opentour\" \"npm run watch:ot-model-loader\" \"npm run watch:ot-tour-loader\" \"npm run watch:ot-tour-player\" \"npm run watch:ot-tour-download\" \"npm run watch:ot-tour-producer\" \"npm run watch:ot-live-stream\" \"npm run serve:opentour\" \"npm run serve:ot-tour-loader\" \"npm run serve:ot-tour-player\" \"npm run serve:ot-tour-download\" \"npm run serve:ot-tour-producer\" \"npm run serve:ot-live-stream\"",
        "develop": "cross-env BUILD_TYPE=debug concurrently --kill-others \"npm run watch\" \"npm run serve\"",
        "develop:auto-launch": "concurrently --kill-others \"xdg-open 'http://localhost:3000/'\" \"npm run watch\" \"npm run serve\"",
        "lint": "eslint src"
    },
    "devDependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@gltf-transform/core": "^4.3.0",
        "@gltf-transform/functions": "^4.3.0",
        "@playcanvas/eslint-config": "2.1.0",
        "@playcanvas/pcui": "5.5.0",
        "@playcanvas/splat-transform": "1.7.2",
        "@rollup/plugin-alias": "6.0.0",
        "@rollup/plugin-image": "3.0.3",
        "@rollup/plugin-json": "6.1.0",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-strip": "3.0.4",
        "@rollup/plugin-terser": "0.4.4",
        "@rollup/plugin-typescript": "12.3.0",
        "@types/wicg-file-system-access": "2023.10.7",
        "@typescript-eslint/eslint-plugin": "8.55.0",
        "@typescript-eslint/parser": "8.55.0",
        "autoprefixer": "10.4.24",
        "better-sqlite3": "^12.6.2",
        "concurrently": "9.2.1",
        "cors": "2.8.6",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "globals": "17.3.0",
        "i18next": "25.8.10",
        "i18next-browser-languagedetector": "8.2.1",
        "i18next-http-backend": "3.0.2",
        "mediabunny": "1.34.2",
        "playcanvas": "2.16.1",
        "playwright": "^1.58.2",
        "postcss": "8.5.6",
        "rollup": "4.57.1",
        "rollup-plugin-scss": "4.0.1",
        "sass": "1.97.3",
        "serve": "14.2.5",
        "tslib": "2.8.1",
        "typescript": "5.9.3",
        "undici": "^7.22.0"
    },
    "dependencies": {
        "@gltf-transform/extensions": "^4.3.0",
        "@google/genai": "^1.46.0",
        "sharp": "^0.34.5",
        "ws": "^8.19.0"
    }
}
