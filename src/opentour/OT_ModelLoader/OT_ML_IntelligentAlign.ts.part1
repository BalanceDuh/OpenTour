        letter-spacing: 0.05em;
    }
    .otml-params-body { padding: 20px; overflow-y: auto; flex: 1; }
    
    .otml-mini-title { font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 0.05em; margin-bottom: 8px; text-transform: uppercase; }
    
    .otml-select {
        width: 100%;
        height: 32px;
        border-radius: 6px;
        border: 1px solid #1e293b;
        background: #020617;
        color: #e2e8f0;
        padding: 0 8px;
