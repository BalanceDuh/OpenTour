    .otml-select:focus { border-color: #3b82f6; }
    
    .otml-check-row { display: flex; gap: 16px; margin-bottom: 32px; }
    .otml-check-row label { display: flex; gap: 6px; align-items: center; font-size: 10px; color: #cbd5e1; cursor: pointer; }
    .otml-check-row input[type="checkbox"] { accent-color: #3b82f6; width: 12px; height: 12px; cursor: pointer; }
    
    .otml-param-group { margin-bottom: 20px; }
    .otml-param-label { font-size: 10px; font-weight: 700; margin-bottom: 6px; letter-spacing: 0.05em; text-transform: uppercase; }
    .otml-param-label.red { color: #ef4444; }
    .otml-param-label.green { color: #10b981; }
    .otml-param-label.blue { color: #3b82f6; }
    
    .otml-minmax { display: flex; gap: 8px; }
    .otml-minmax .cell { flex: 1; display: flex; align-items: center; gap: 6px; border: 1px solid #1e293b; border-radius: 6px; background: #020617; padding: 6px 8px; }
    .otml-minmax .tag { color: #64748b; font-size: 9px; font-weight: 500; }
    .otml-minmax input, .otml-single input { width: 100%; border: none; background: transparent; color: #e2e8f0; font-size: 12px; outline: none; }
    
    .otml-twin { display: flex; gap: 12px; margin-top: 24px; margin-bottom: 8px; }
    .otml-twin-col { flex: 1; display: flex; flex-direction: column; }
    .otml-single { border: 1px solid #1e293b; border-radius: 6px; background: #020617; padding: 6px 8px; display: flex; align-items: center; }

    /* CENTER MAIN PANEL */
    .otml-main { padding: 20px; display: flex; flex-direction: column; gap: 16px; overflow-y: auto; }
    
    .otml-pane {
        border: 1px solid rgba(30, 41, 59, 0.6);
        border-radius: 12px;
        background: rgba(15, 23, 42, 0.4);
        padding: 12px;
        display: flex;
        flex-direction: column;
    }
    .otml-pane.active { border-color: #3b82f6; box-shadow: 0 0 15px rgba(59, 130, 246, 0.15); }
    
    .otml-pane-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; padding: 0 4px; }
    .otml-pane-title { font-size: 12px; font-weight: 500; color: #cbd5e1; }
    .otml-pane-actions { display: flex; gap: 4px; }
    
    .otml-icon-btn {
