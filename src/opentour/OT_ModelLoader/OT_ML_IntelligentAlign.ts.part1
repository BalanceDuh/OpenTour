        transition: all 0.2s;
    }
    .otml-icon-btn:hover { color: #e2e8f0; border-color: #475569; }
    
    .otml-pair { display: flex; gap: 12px; flex: 1; min-height: 0; }
    
    .otml-canvas-card {
        flex: 1;
        border: 1px solid rgba(30, 41, 59, 0.8);
        border-radius: 4px;
        background: #020617;
