        border-radius: 4px;
        border: 1px solid #334155;
        background: rgba(15, 23, 42, 0.8);
        color: #94a3b8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        cursor: pointer;
    }
    .otml-vp-btn:hover { color: #e2e8f0; background: #1e293b; }

