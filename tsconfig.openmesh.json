{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2020",
        "moduleResolution": "bundler",
        "lib": ["es2022", "dom"],
        "sourceMap": true,
        "noImplicitAny": true,
        "inlineSources": true,
        "resolveJsonModule": true
    },
    "include": [
        "./src/openmesh/**/*.ts",
        "global.d.ts"
    ],
    "exclude": [
        "dist",
        "dist-openmesh",
        "node_modules"
    ]
}
